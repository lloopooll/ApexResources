Auto generate pdf using queueable
----------------------------------------------------------------------------------------------------------

generate a PDF automatically and store it in Salesforce Files.

---

#  Requirement

* Generate PDF using Visualforce
* Run asynchronously (Queueable)
* Save as **File (ContentVersion)**
* Trigger automatically (example: after insert)

---

#  1. Visualforce Page (PDF Template)

```xml id="vf1"
<apex:page renderAs="pdf" standardController="Account">

    <h2>Account Report</h2>

    <p><b>Name:</b> {!Account.Name}</p>
    <p><b>Phone:</b> {!Account.Phone}</p>
    <p><b>Industry:</b> {!Account.Industry}</p>

</apex:page>
```

---

#  2. Queueable Class (PDF Generator)

public class AccountPdfQueueable implements Queueable {

    private Id accountId;

    public AccountPdfQueueable(Id accountId) {
        this.accountId = accountId;
    }

    public void execute(QueueableContext context) {

        try {

            // Load Visualforce Page
            PageReference pdfPage = Page.AccountPdfPage;
            pdfPage.getParameters().put('id', accountId);

            // Generate PDF
            Blob pdfBlob = pdfPage.getContentAsPDF();

            // Save as File
            ContentVersion cv = new ContentVersion();
            cv.Title = 'Account_Report_' + accountId;
            cv.PathOnClient = 'Account.pdf';
            cv.VersionData = pdfBlob;

            insert cv;

            // Link file to Account
            ContentDocumentLink cdl = new ContentDocumentLink();
            cdl.ContentDocumentId = [
                SELECT ContentDocumentId
                FROM ContentVersion
                WHERE Id = :cv.Id
            ].ContentDocumentId;

            cdl.LinkedEntityId = accountId;
            cdl.ShareType = 'V';
            cdl.Visibility = 'AllUsers';

            insert cdl;

        } catch (Exception e) {
            System.debug('PDF generation failed: ' + e.getMessage());
        }
    }
}
```

---

# 3. Trigger to Auto-Invoke Queueable

trigger AccountTrigger on Account (after insert) {

    for (Account acc : Trigger.new) {

        System.enqueueJob(new AccountPdfQueueable(acc.Id));
    }
}
```

