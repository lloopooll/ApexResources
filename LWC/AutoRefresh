-------------------------------------------------
// HTML
-------------------------------------------------
<template>
    <lightning-card title="Automated Refresh after Accounts creation" icon-name="standard:account">
        
        <div slot="actions">
            <lightning-button label="Refresh" icon-name="utility:refresh" onclick={handleManualRefresh} class="slds-m-right_x-small"></lightning-button>
            <lightning-button label="Add Account" icon-name="utility:add" variant="brand" onclick={openStandardNewRecordPage}></lightning-button>
        </div>

        <div class="slds-m-around_medium">
            <template if:true={accounts.length}>
                <div style="height: 300px;">
                    <lightning-datatable
                        key-field="Id"
                        data={accounts}
                        columns={columns}
                        onrowaction={handleRowAction}
                        hide-checkbox-column>
                    </lightning-datatable>
                </div>
            </template>

            <template if:true={error}>
                <div class="slds-text-color_error slds-p-vertical_small">Error processing data retrieval logic.</div>
            </template>

            <div class="slds-m-top_medium slds-grid slds-grid_align-center slds-grid_vertical-align-center">
                <div class="slds-button-group" role="group">
                    <button class="slds-button slds-button_neutral" onclick={handlePrevious} disabled={isFirstPage}>Previous</button>

                    <template for:each={visiblePages} for:item="page">
                        <template if:true={page.isPage}>
                            <button key={page.label} data-page={page.label} onclick={handlePageClick} style="font-weight: bold;" class="slds-button slds-button_neutral" disabled={page.active}>
                                {page.label}
                            </button>
                        </template>
                        <template if:false={page.isPage}>
                            <span key={page.label} class="slds-p-horizontal_small slds-align-middle">
                                {page.label}
                            </span>
                        </template>
                    </template>

                    <button class="slds-button slds-button_neutral" onclick={handleNext} disabled={isLastPage}>Next</button>
                </div>
            </div>
            
            <div class="slds-text-align_center slds-m-top_x-small slds-text-color_weak">
                Page {pageNumber} of {totalPages} (Total Records: {totalCount})
            </div>
        </div>
    </lightning-card>
</template>
-------------------------------------------------
// JS
-------------------------------------------------
import { LightningElement, wire, track } from 'lwc';
import { NavigationMixin } from 'lightning/navigation';
import { refreshApex } from '@salesforce/apex';
import { ShowToastEvent } from 'lightning/platformShowToastEvent';
import { deleteRecord } from 'lightning/uiRecordApi';
import { subscribe, unsubscribe, onError } from 'lightning/empApi';
import getAccounts from '@salesforce/apex/AutoRefreshAccountController.getAccounts';

const ROW_ACTIONS = [
    { label: 'Edit', name: 'edit', iconName: 'utility:edit' },
    { label: 'Delete', name: 'delete', iconName: 'utility:delete' }
];

export default class AutoRefreshDatatable extends NavigationMixin(LightningElement) {
    @track accounts = [];
    @track error;
    
    pageSize = 10;
    pageNumber = 1;
    totalCount = 0;
    totalPages = 0;
    visiblePages = [];
    wiredAccountsResult; 
    
    // EMP API Subscription tracking
    channelName = '/data/AccountChangeEvent';
    subscription = {};

    columns = [
        { label: 'Account Name', fieldName: 'Name' },
        { label: 'Phone', fieldName: 'Phone', type: 'phone' },
        { label: 'Industry', fieldName: 'Industry' },
        {
            type: 'action',
            typeAttributes: { rowActions: ROW_ACTIONS, menuAlignment: 'right' }
        }
    ];

    @wire(getAccounts, { pageSize: '$pageSize', pageNumber: '$pageNumber' })
    wiredAccounts(result) {
        this.wiredAccountsResult = result;
        const { error, data } = result;
        if (data) {
            this.accounts = data.records;
            this.totalCount = data.totalCount;
            this.totalPages = Math.ceil(this.totalCount / this.pageSize);
            this.generatePageLinks();
            this.error = undefined;
        } else if (error) {
            this.error = error;
            this.accounts = [];
        }
    }

    // Connect to EMP API on load
    connectedCallback() {
        this.handleSubscribe();
        this.registerErrorListener();
    }

    // Disconnect from EMP API to prevent memory leaks
    disconnectedCallback() {
        this.handleUnsubscribe();
    }

    // --- EMP API / Change Data Capture Logic ---
    handleSubscribe() {
        const messageCallback = (response) => {
            // A change happened in the database (Create, Update, Delete)
            console.log('Database Change Detected: ', JSON.stringify(response));
            
            // If it was a brand new record, optionally bump user back to page 1 to see it
            if(response.data.payload.ChangeEventHeader.changeType === 'CREATE') {
                this.pageNumber = 1;
            }
            
            // Force the Datatable to refresh
            refreshApex(this.wiredAccountsResult);
        };

        // Subscribe to the Account Change Event channel
        subscribe(this.channelName, -1, messageCallback).then((response) => {
            this.subscription = response;
        });
    }

    handleUnsubscribe() {
        unsubscribe(this.subscription, (response) => {
            console.log('Unsubscribed from EMP API');
        });
    }

    registerErrorListener() {
        onError((error) => {
            console.error('EMP API Error: ', JSON.stringify(error));
        });
    }

    // --- Standard Navigation Logic ---
    handleRowAction(event) {
        const actionName = event.detail.action.name;
        const row = event.detail.row;

        switch (actionName) {
            case 'edit':
                // Opens standard Edit modal
                this[NavigationMixin.Navigate]({
                    type: 'standard__recordPage',
                    attributes: {
                        recordId: row.Id,
                        objectApiName: 'Account',
                        actionName: 'edit'
                    }
                });
                break;
            case 'delete':
                this.executeRecordDeletion(row.Id);
                break;
            default:
                break;
        }
    }

    // Opens standard New Record modal
    openStandardNewRecordPage() {
        this[NavigationMixin.Navigate]({
            type: 'standard__objectPage',
            attributes: {
                objectApiName: 'Account',
                actionName: 'new'
            }
        });
    }

    async executeRecordDeletion(recordId) {
        try {
            await deleteRecord(recordId);
            this.showToast('Success', 'Account deleted successfully', 'success');
            
            if (this.accounts.length === 1 && this.pageNumber > 1) {
                this.pageNumber--;
            } 
            // Note: EMP API will actually catch the delete and refresh anyway, 
            // but keeping this here for immediate UI response.
        } catch (error) {
            this.showToast('Error Deleting Record', error.body.message, 'error');
        }
    }

    async handleManualRefresh() {
        try {
            await refreshApex(this.wiredAccountsResult);
            this.showToast('Success', 'Data refreshed successfully', 'success');
        } catch (error) {
            this.showToast('Error', 'Error refreshing data', 'error');
        }
    }

    // --- Pagination Logic ---
    generatePageLinks() {
        const pages = [];
        const total = this.totalPages;
        const current = this.pageNumber;

        if (total <= 4) {
            for (let i = 1; i <= total; i++) {
                pages.push({ label: i, isPage: true, active: i === current });
            }
        } else {
            pages.push({ label: 1, isPage: true, active: current === 1 });
            pages.push({ label: 2, isPage: true, active: current === 2 });

            if (current > 2 && current < total - 1) {
                if (current > 3) pages.push({ label: '...', isPage: false });
                pages.push({ label: current, isPage: true, active: true });
                if (current < total - 2) pages.push({ label: '...', isPage: false });
            } else {
                pages.push({ label: '...', isPage: false });
            }

            pages.push({ label: total - 1, isPage: true, active: current === total - 1 });
            pages.push({ label: total, isPage: true, active: current === total });
        }
        this.visiblePages = pages;
    }

    handlePrevious() { if (this.pageNumber > 1) this.pageNumber--; }
    handleNext() { if (this.pageNumber < this.totalPages) this.pageNumber++; }
    
    handlePageClick(event) {
        const pageClicked = parseInt(event.target.dataset.page, 10);
        if (pageClicked && pageClicked !== this.pageNumber) {
            this.pageNumber = pageClicked;
        }
    }

    get isFirstPage() { return this.pageNumber === 1; }
    get isLastPage() { return this.pageNumber === this.totalPages || this.totalPages === 0; }

    showToast(title, message, variant) {
        this.dispatchEvent(new ShowToastEvent({ title, message, variant }));
    }
}
