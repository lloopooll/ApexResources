  <template>
    <lightning-card title="Upload CSV to Create Accounts" icon-name="utility:upload">
        <div class="slds-m-around_medium">
            <template if:true={isLoading}>
                <lightning-spinner alternative-text="Processing File" size="medium"></lightning-spinner>
            </template>

            <div class="slds-notify slds-notify_alert slds-alert_warning slds-m-bottom_medium" role="alert">
                <h2>Expected Header Format: <strong>Name, Phone, Industry, Website</strong></h2>
            </div>

            <lightning-input 
                type="file" 
                accept=".csv" 
                label="Choose CSV File" 
                onchange={handleFileChange}>
            </lightning-input>

            <template if:true={fileName}>
                <p class="slds-m-top_small slds-text-color_weak">Selected File: {fileName}</p>
            </template>

            <div class="slds-m-top_medium">
                <lightning-button 
                    label="Generate Records" 
                    variant="brand" 
                    icon-name="utility:add"
                    onclick={handleUpload}
                    disabled={isFileDisabled}>
                </lightning-button>
            </div>
        </div>
    </lightning-card>
</template>
