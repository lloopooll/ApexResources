  public with sharing class CSVUploadController {
    @AuraEnabled
    public static String uploadCSVRows(String base64Data) {
        try {
            // 1. Decode the Base64 file string sent from the LWC
            Blob fileBlob = EncodingUtil.base64Decode(base64Data);
            String csvString = fileBlob.toString();
            
            // 2. Split file content by line breaks
            List<String> csvLines = csvString.split('\n');
            if (csvLines.isEmpty() || csvLines.size() <= 1) {
                throw new AuraHandledException('The uploaded CSV file is empty.');
            }

            List<Account> accountsToInsert = new List<Account>();

            // 3. Loop through lines (skipping the header at index 0)
            // Example CSV Header Format: Name,Phone,Industry,Website
            for (Integer i = 1; i < csvLines.size(); i++) {
                String line = csvLines[i].trim();
                if (String.isBlank(line)) {
                    continue;
                }
                
                List<String> csvRowValues = line.split(',');
                
                // Safety check: Make sure your CSV row matches expected columns
                if (csvRowValues.size() >= 4) {
                    Account acc = new Account();
                    acc.Name     = csvRowValues[0].trim();
                    acc.Phone    = csvRowValues[1].trim();
                    acc.Industry = csvRowValues[2].trim();
                    acc.Website  = csvRowValues[3].trim();
                    accountsToInsert.add(acc);
                }
            }

            // 4. Batch insert your mapped records safely
            if (!accountsToInsert.isEmpty()) {
                insert accountsToInsert;
                return accountsToInsert.size() + ' Accounts created successfully!';
            } else {
                return 'No valid rows found to process.';
            }

        } catch (Exception ex) {
            throw new AuraHandledException('Error processing CSV: ' + ex.getMessage());
        }
    }
}
