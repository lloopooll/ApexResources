// JS
-------------------------------------------------
import { LightningElement, track } from 'lwc';
import { ShowToastEvent } from 'lightning/platformShowToastEvent';
import uploadCSVRows from '@salesforce/apex/CSVUploadController.uploadCSVRows';

export default class CsvRecordUploader extends LightningElement {
    @track fileName = '';
    @track isLoading = false;
    
    fileReader;
    fileRawData;

    // Returns true to lock button if a file isn't uploaded yet
    get isFileDisabled() {
        return !this.fileRawData;
    }

    // Handles the selection of a file
    handleFileChange(event) {
        if (event.target.files.length > 0) {
            const file = event.target.files[0];
            this.fileName = file.name;
            
            // Instantiate standard browser file reader
            this.fileReader = new FileReader();
            
            this.fileReader.onloadend = () => {
                // Split off the metadata tag prefix (e.g. "data:text/csv;base64,")
                const base64Content = this.fileReader.result.split(',')[1];
                this.fileRawData = base64Content;
            };

            // Read the file as a DataURL format structure
            this.fileReader.readAsDataURL(file);
        }
    }

    // Sends Base64 context payload to Salesforce Apex
    handleUpload() {
        if (!this.fileRawData) return;

        this.isLoading = true;

        uploadCSVRows({ base64Data: this.fileRawData })
            .then(result => {
                this.showToast('Success', result, 'success');
                this.fileRawData = null;
                this.fileName = '';
            })
            .catch(error => {
                this.showToast('Error processing file', error.body.message, 'error');
            })
            .finally(() => {
                this.isLoading = false;
            });
    }

    showToast(title, message, variant) {
        this.dispatchEvent(new ShowToastEvent({ title, message, variant }));
    }
}
