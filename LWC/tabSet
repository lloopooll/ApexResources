public with sharing class TabsetController {

    @AuraEnabled(cacheable=true)
    public static List<Contact> getContactList() {
        return [SELECT Id, Name, Email, AccountId, Account.Name 
                FROM Contact 
                WHERE AccountId != null 
                LIMIT 50];
    }
}
