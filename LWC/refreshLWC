// Apex ...................................................................................

public with sharing class MetricsDashboardController {
    
    // Wrapper class to send all data at once to the LWC
    public class SystemMetrics {
        @AuraEnabled public Integer totalAccounts { get; set; }
        @AuraEnabled public Integer totalContacts { get; set; }
        @AuraEnabled public Integer totalOpportunities { get; set; }
    }

    @AuraEnabled(cacheable=true)
    public static SystemMetrics getLiveMetrics() {
        SystemMetrics metrics = new SystemMetrics();
        
        // Count records 
        metrics.totalAccounts = [SELECT COUNT() FROM Account];
        metrics.totalContacts = [SELECT COUNT() FROM Contact];
        metrics.totalOpportunities = [SELECT COUNT() FROM Opportunity];
        
        return metrics;
    }
}

// HTML ...................................................................................

<template>
    <lightning-card title="Manual Refresh Example" icon-name="action:refresh">
        
        <div slot="actions">
            <lightning-button 
                label="Refresh Component" 
                icon-name="utility:refresh" 
                variant="brand" 
                onclick={handleFullRefresh}>
            </lightning-button>
        </div>

        <div class="slds-m-around_medium slds-is-relative">
            
            <template if:true={isLoading}>
                <lightning-spinner alternative-text="Loading..." size="medium" variant="brand"></lightning-spinner>
            </template>

            <div class="slds-box slds-theme_default slds-m-bottom_medium">
                <p class="slds-text-heading_medium">Total Accounts: <b>{metrics.totalAccounts}</b></p>
                <p class="slds-text-heading_medium slds-m-top_small">Total Contacts: <b>{metrics.totalContacts}</b></p>
            </div>

            <div class="slds-text-align_right slds-text-color_weak slds-text-body_small">
                Last completely refreshed at: {lastRefreshed}
            </div>

        </div>
    </lightning-card>
</template>

// JS ...................................................................................

import { LightningElement, wire, track } from 'lwc';
import { refreshApex } from '@salesforce/apex';
import { ShowToastEvent } from 'lightning/platformShowToastEvent';
import getLiveMetrics from '@salesforce/apex/MetricsDashboardController.getLiveMetrics'; // Replace with your Apex

export default class RefreshLWC extends LightningElement {
    @track metrics = {};
    @track lastRefreshed = new Date().toLocaleTimeString();
    @track isLoading = false; // Controls the loading spinner
    
    wiredDataResult; // Stores the wire provisioning for refreshApex

    @wire(getLiveMetrics)
    wiredData(result) {
        this.wiredDataResult = result;
        if (result.data) {
            this.metrics = result.data;
        } else if (result.error) {
            console.error('Error loading data', result.error);
        }
    }

    // --- The Complete Refresh Function ---
    async handleFullRefresh() {
        // 1. Turn on the spinner to block the UI temporarily
        this.isLoading = true; 

        try {
            // 2. Force the server to send fresh database records
            await refreshApex(this.wiredDataResult);
            
            // 3. Reset any local state/variables back to default here
            this.lastRefreshed = new Date().toLocaleTimeString();
            
            // 4. Show success message
            this.showToast('Refreshed', 'Component data and state reloaded successfully.', 'success');
        } catch (error) {
            this.showToast('Error', 'Failed to refresh component.', 'error');
        } finally {
            // 5. Turn off the spinner
            this.isLoading = false; 
        }
    }

    showToast(title, message, variant) {
        this.dispatchEvent(new ShowToastEvent({ title, message, variant }));
    }
}

