  <template>
    <lightning-card title="Car Wash Waiting List" icon-name="standard:contact" >
        <div slot="actions">
            <lightning-button label="Refresh" icon-name="utility:refresh" onclick={handleRefresh} class="slds-m-right_x-small"></lightning-button>
            <lightning-button label="Book" icon-name="utility:add" variant="brand" onclick={openStandardNewRecordPage}></lightning-button>
        </div>
        
        <div class="slds-m-around_medium slds-box slds-box_x-small slds-theme_default">
            <template if:true={data}>
                <lightning-datatable 
                    data={data}
                    columns={columns}
                    key-field="id"
                    sorted-by={sortBy}
                    sorted-direction={sortDirection}
                    onsort={doSorting}
                    hide-checkbox-column="true"
                    class="slds-table_bordered">
                </lightning-datatable>
            </template>
        </div>
    </lightning-card>
</template>
