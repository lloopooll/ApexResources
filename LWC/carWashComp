  public with sharing class CarWashApexController {
    @AuraEnabled(cacheable=true)
    public static List <CarWaitingList__c> getRecords() {
        List<CarWaitingList__c> waitList = [ SELECT Id, Name, Customer_Name__c, Car_Type__c, Washing_Center__c, Waiting_Time__c, Cost__c, Status__c
                                   FROM CarWaitingList__c
                                   LIMIT 10 ];
        return waitList;
    }   

    @AuraEnabled(cacheable=true)
    public static List<CarWaitingList__c> getWaitingList() {
        return [SELECT Id, Name, Customer_Name__c FROM CarWaitingList__c
        WHERE Washing_Center__c ='W-1'  ORDER BY CreatedDate ASC];
    }
}
