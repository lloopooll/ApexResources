import { LightningElement, wire, track } from 'lwc';
import { ShowToastEvent } from 'lightning/platformShowToastEvent';
import { NavigationMixin } from 'lightning/navigation'; // Added for standard record creation page access
import { refreshApex } from '@salesforce/apex';
import getRecordsPaged from '@salesforce/apex/ShipmentController.getRecordsPaged';
import ROCKET_ICON_URL from '@salesforce/resourceUrl/rocketIcon';

export default class CardsWithModalAndEditbutton extends NavigationMixin(LightningElement) {
    @track isModalOpen = false;
    @track selectedShipmentId;
    @track selectedAccountId;
    @track modalMode = ''; // 'shipment' or 'account'

    @track searchKey = '';
    @track selectedStatus = '';
    @track pageNumber = 1;
    pageSize = 10;

    rocketIcon = ROCKET_ICON_URL;

    totalRecordCount = 0;
    wiredRecordsResult;
    refreshIntervalId;

    @wire(getRecordsPaged, {
        searchKey: '$searchKey',
        status: '$selectedStatus',
        pageSize: '$pageSize',
        pageNumber: '$pageNumber'
    })
    wiredShipments(result) {
        this.wiredRecordsResult = result;
        if (result.data) {
            this.totalRecordCount = result.data.totalRecordCount;
        } else if (result.error) {
            this.showToast('Error', 'Failed to retrieve shipments', 'error');
        }
    }

    connectedCallback() {
        this.refreshIntervalId = setInterval(() => {
            this.autoRefreshData();
        }, 30000);
    }

    disconnectedCallback() {
        if (this.refreshIntervalId) {
            clearInterval(this.refreshIntervalId);
        }
    }

    async autoRefreshData() {
        if (this.wiredRecordsResult && !this.isModalOpen) {
            await refreshApex(this.wiredRecordsResult);
        }
    }

    // Opens the standard Salesforce modal to create a new testShipment__c record
    openStandardNewRecordPage() {
        this[NavigationMixin.Navigate]({
            type: 'standard__objectPage',
            attributes: {
                objectApiName: 'testShipment__c',
                actionName: 'new'
            }
        });
    }

    // Search Logic
    handleSearchChange(event) {
        this.searchKey = event.target.value;
        this.pageNumber = 1;
    }

    // Filter Logic
    handleIndustryFilter(event) {
        this.selectedStatus = event.target.dataset.industry;
        this.pageNumber = 1;
    }

    // Getters mapping background colors dynamically to each shipment status
    get paginatedContacts() {
        const shipments = this.wiredRecordsResult?.data?.shipments || [];

        return shipments.map(ship => {
            let statusClass = 'status-badge ';

            // Dynamic status classes
            if (ship.Status__c === 'Pending') {
                statusClass += 'status-pending';
            } else if (ship.Status__c === 'Delivered') {
                statusClass += 'status-delivered';
            } else if (ship.Status__c === 'Failed') {
                statusClass += 'status-failed';
            } else {
                statusClass += 'status-default';
            }

            return {
                ...ship,
                statusClass: statusClass,
                // Dynamic boolean flag for the icon
                isExpress: ship.Shipment_Type__c === 'Express'
            };
        });
    }

    get totalPages() {
        return Math.ceil(this.totalRecordCount / this.pageSize) || 1;
    }

    get hasRecords() {
        return this.paginatedContacts.length > 0;
    }

    get isFirstPage() { return this.pageNumber === 1; }
    get isLastPage() { return this.pageNumber >= this.totalPages; }

    handlePreviousPage() { if (this.pageNumber > 1) this.pageNumber--; }
    handleNextPage() { if (this.pageNumber < this.totalPages) this.pageNumber++; }

    get allButtonVariant() { return this.selectedStatus === '' ? 'brand' : 'neutral'; }
    get pendingButtonVariant() { return this.selectedStatus === 'Pending' ? 'brand' : 'neutral'; }
    get deliveredButtonVariant() { return this.selectedStatus === 'Delivered' ? 'brand' : 'neutral'; }
    get failedButtonVariant() { return this.selectedStatus === 'Failed' ? 'brand' : 'neutral'; }

    // Clicked Pencil Icon: Change lookup assignment
    handlePencilClick(event) {
        this.selectedShipmentId = event.currentTarget.dataset.shipmentId;
        this.modalMode = 'shipment';
        this.isModalOpen = true;
    }

    // Clicked Account Name Link: View Account Details directly
    handleAccountClick(event) {
        this.selectedAccountId = event.currentTarget.dataset.accountId;
        this.modalMode = 'account';
        this.isModalOpen = true;
    }

    // Getters for dynamic modal context layout
    get isShipmentMode() { return this.modalMode === 'shipment'; }
    get isAccountMode() { return this.modalMode === 'account'; }
    get modalTitle() {
        return this.modalMode === 'shipment' ? 'Update Shipment Assignment' : 'Account Information';
    }

    closeModal() {
        this.isModalOpen = false;
        this.selectedShipmentId = null;
        this.selectedAccountId = null;
        this.modalMode = '';
    }

    handleSuccess() {
        this.showToast('Success', 'Record updated successfully!', 'success');
        this.closeModal();
        return refreshApex(this.wiredRecordsResult);
    }

    showToast(title, message, variant) {
        this.dispatchEvent(new ShowToastEvent({ title, message, variant }));
    }
}
