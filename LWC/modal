<template>
    <lightning-card title="Unified ShipSmart Control Center" icon-name="standard:contact">

        <div slot="actions">
            <lightning-button label="New" icon-name="utility:add" variant="brand"
                onclick={openStandardNewRecordPage}></lightning-button>
        </div>

        <lightning-card>
            <div
                class="slds-m-around_medium slds-grid slds-grid_vertical-align-center slds-grid_align-spread slds-wrap">

                <div class="slds-col slds-m-bottom_x-small slds-small-m-bottom_none">
                    <lightning-button-group>
                        <lightning-button label="All" variant={allButtonVariant} data-industry=""
                            onclick={handleIndustryFilter}>
                        </lightning-button>
                        <lightning-button label="Pending" variant={pendingButtonVariant} data-industry="Pending"
                            onclick={handleIndustryFilter}>
                        </lightning-button>
                        <lightning-button label="Delivered" variant={deliveredButtonVariant} data-industry="Delivered"
                            onclick={handleIndustryFilter}>
                        </lightning-button>
                        <lightning-button label="Failed" variant={failedButtonVariant} data-industry="Failed"
                            onclick={handleIndustryFilter}>
                        </lightning-button>
                    </lightning-button-group>
                </div>

                <div class="slds-col slds-size_1-of-1 slds-small-size_2-of-5">
                    <lightning-input type="search" variant="label-hidden"
                        placeholder="Search by Name, Email, or Website..." value={searchKey}
                        onchange={handleSearchChange}>
                    </lightning-input>
                </div>
            </div>

            <div class="slds-p-horizontal_medium">
                <lightning-layout multiple-rows="true">
                    <template if:true={hasRecords}>
                        <template for:each={paginatedContacts} for:item="con">
                            <lightning-layout-item key={con.Id} size="12" small-size="6" medium-size="4"
                                class="slds-p-around_small five-cols-per-row">
                                <div class="slds-box slds-box_x-small slds-theme_default slds-position_relative">
                                    <div class="slds-media slds-media_center">
                                        <div class="slds-media__figure">
                                            <lightning-icon icon-name="standard:contact" size="medium"></lightning-icon>
                                        </div>
                                        <div class="slds-media__body">
                                            <h2 class="slds-text-heading_small slds-grid slds-grid_vertical-align-center"
                                                title={con.Name}>
                                                <span class="slds-truncate slds-m-right_xx-small">{con.Name}</span>

                                                <template if:true={con.isExpress}>
                                                    <img src={rocketIcon} alt="Express Shipment"
                                                        title="Express Shipment"
                                                        class="custom-rocket-icon slds-m-left_xx-small" />
                                                </template>
                                            </h2>

                                            <p class="slds-text-body_small slds-truncate">Destination Address:
                                                {con.Destination_Address__c}</p>
                                            <p class="slds-text-body_small slds-truncate">Shipment Type:
                                                {con.Shipment_Type__c}</p>
                                            <p class="slds-text-body_small slds-truncate slds-m-vertical_xx-small">
                                                <span>Status: </span>
                                                <span class={con.statusClass}>{con.Status__c}</span>
                                            </p>
                                            <p class="slds-text-body_small slds-truncate">COD Amount:
                                                {con.COD_Amount__c}</p>
                                            <p
                                                class="slds-text-body_small slds-truncate slds-grid slds-grid_vertical-align-center">
                                                <span>Account:&nbsp;</span>
                                                <template if:true={con.Account__c}>
                                                    <span class="slds-grid slds-grid_vertical-align-center">
                                                        <a href="javascript:void(0);" data-account-id={con.Account__c}
                                                            onclick={handleAccountClick}>
                                                            {con.Account__r.Name}
                                                        </a>
                                                        <lightning-button-icon icon-name="utility:edit" variant="bare"
                                                            alternative-text="Change Linked Account"
                                                            title="Change Linked Account" data-shipment-id={con.Id}
                                                            onclick={handlePencilClick} class="slds-m-left_xx-small">
                                                        </lightning-button-icon>
                                                    </span>
                                                </template>
                                                <template if:false={con.Account__c}>
                                                    <span class="slds-grid slds-grid_vertical-align-center">
                                                        <span class="slds-text-color_weak">None</span>
                                                        <lightning-button-icon icon-name="utility:edit" variant="bare"
                                                            alternative-text="Link Account" title="Link Account"
                                                            data-shipment-id={con.Id} onclick={handlePencilClick}
                                                            class="slds-m-left_xx-small">
                                                        </lightning-button-icon>
                                                    </span>
                                                </template>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </lightning-layout-item>
                        </template>
                    </template>

                    <template if:false={hasRecords}>
                        <div
                            class="slds-align_absolute-center slds-m-vertical_large slds-text-heading_small slds-text-color_weak">
                            No matching records found.
                        </div>
                    </template>
                </lightning-layout>

                <div class="slds-m-top_medium slds-grid slds-grid_align-center slds-grid_vertical-align-center">
                    <lightning-button label="Previous" icon-name="utility:chevronleft" variant="neutral"
                        disabled={isFirstPage} onclick={handlePreviousPage} class="slds-m-right_small">
                    </lightning-button>

                    <span class="slds-text-body_medium slds-m-horizontal_small">
                        Page <strong>{pageNumber}</strong> of {totalPages}
                    </span>

                    <lightning-button label="Next" icon-name="utility:chevronright" variant="neutral"
                        icon-position="right" disabled={isLastPage} onclick={handleNextPage} class="slds-m-left_small">
                    </lightning-button>
                </div>
            </div>

            <template if:true={isModalOpen}>
                <section role="dialog" tabindex="-1" aria-modal="true" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container">
                        <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse"
                            title="Close" onclick={closeModal}>
                            <lightning-icon icon-name="utility:close" alternative-text="close" variant="inverse"
                                size="small"></lightning-icon>
                        </button>
                        <header class="slds-modal__header">
                            <h2 class="slds-modal__title slds-hyphenate">{modalTitle}</h2>
                        </header>

                        <div class="slds-modal__content slds-p-around_medium">
                            <template if:true={isShipmentMode}>
                                <lightning-record-edit-form record-id={selectedShipmentId}
                                    object-api-name="testShipment__c" onsuccess={handleSuccess}>
                                    <lightning-messages></lightning-messages>
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-2 slds-p-around_x-small">
                                            <lightning-output-field field-name="Name"></lightning-output-field>
                                        </div>
                                        <div class="slds-col slds-size_1-of-2 slds-p-around_x-small">
                                            <lightning-input-field field-name="Account__c"></lightning-input-field>
                                        </div>
                                    </div>
                                    <footer class="slds-modal__footer slds-m-top_medium slds-p-right_none">
                                        <lightning-button class="slds-m-right_small" label="Cancel"
                                            onclick={closeModal}></lightning-button>
                                        <lightning-button type="submit" variant="brand"
                                            label="Save Assignment"></lightning-button>
                                    </footer>
                                </lightning-record-edit-form>
                            </template>

                            <template if:true={isAccountMode}>
                                <lightning-record-edit-form record-id={selectedAccountId} object-api-name="Account"
                                    onsuccess={handleSuccess}>
                                    <lightning-messages></lightning-messages>
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-2 slds-p-around_x-small">
                                            <lightning-output-field field-name="Name"></lightning-output-field>
                                        </div>
                                        <div class="slds-col slds-size_1-of-2 slds-p-around_x-small">
                                            <lightning-output-field field-name="Phone"></lightning-output-field>
                                        </div>
                                        <div class="slds-col slds-size_1-of-2 slds-p-around_x-small">
                                            <lightning-output-field field-name="Website"></lightning-output-field>
                                        </div>
                                        <div class="slds-col slds-size_1-of-2 slds-p-around_x-small">
                                            <lightning-input-field field-name="Industry"></lightning-input-field>
                                        </div>
                                    </div>
                                    <footer class="slds-modal__footer slds-m-top_medium slds-p-right_none">
                                        <lightning-button class="slds-m-right_small" label="Cancel"
                                            onclick={closeModal}></lightning-button>
                                        <lightning-button type="submit" variant="brand"
                                            label="Save Account Details"></lightning-button>
                                    </footer>
                                </lightning-record-edit-form>
                            </template>
                        </div>
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open" role="presentation"></div>
            </template>
        </lightning-card>
    </lightning-card>
</template>
