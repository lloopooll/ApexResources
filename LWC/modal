@media (min-width: 1024px) {
    .five-cols-per-row {
        flex: 0 0 20% !important;
        max-width: 20% !important;
    }
}

/* Custom Status Badges */
.status-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 12px;
    font-weight: bold;
    color: #ffffff !important;
    font-size: 11px;
    text-transform: uppercase;
}

.status-pending {
    background-color: #ff9f00; /* Orange */
}

.status-delivered {
    background-color: #2e7d32; /* Green */
}

.status-failed {
    background-color: #d32f2f; /* Red */
}

.status-default {
    background-color: #747474; /* Grey fallback */
}

/* Keeps your custom rocket aligned with the text and properly sized */
.custom-rocket-icon {
    width: 16px;
    height: 16px;
    vertical-align: middle;
    object-fit: contain;
}
