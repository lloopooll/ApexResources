import { LightningElement, wire, track } from 'lwc';
import { NavigationMixin } from 'lightning/navigation';
import { refreshApex } from '@salesforce/apex';
import getLiveMetrics from '@salesforce/apex/MetricsDashboardController.getLiveMetrics';

export default class AutoRefreshLWC30sec extends NavigationMixin(LightningElement) {
    @track metrics = {
        totalAccounts: 0,
        totalContacts: 0,
        totalOpportunities: 0
    };
    
    wiredMetricsResult; // Retained to force refreshes
    refreshTimer; // Holds the 30-second interval ID

    @wire(getLiveMetrics)
    wiredMetrics(result) {
        this.wiredMetricsResult = result;
        if (result.data) {
            this.metrics = result.data;
        } else if (result.error) {
            console.error('Error fetching metrics', result.error);
        }
    }

    // Start the 30-second countdown when the component loads
    connectedCallback() {
        this.refreshTimer = setInterval(() => {
            refreshApex(this.wiredMetricsResult);
            console.log('Background 30s auto-refresh executed');
        }, 30000); // 30,000 ms = 30 seconds
    }

    // Destroy the timer when the user leaves the page to prevent memory leaks
    disconnectedCallback() {
        if (this.refreshTimer) {
            clearInterval(this.refreshTimer);
        }
    }

    // --- Standard Navigation Actions ---
    createAccount() { this.navigateToNewRecord('Account'); }
    createContact() { this.navigateToNewRecord('Contact'); }
    createOpportunity() { this.navigateToNewRecord('Opportunity'); }

    navigateToNewRecord(objectApiName) {
        this[NavigationMixin.Navigate]({
            type: 'standard__objectPage',
            attributes: {
                objectApiName: objectApiName,
                actionName: 'new'
            }
        });
    }
}

