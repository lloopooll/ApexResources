import { LightningElement, wire } from 'lwc';
import { loadScript } from 'lightning/platformResourceLoader';
import chartjs from '@salesforce/resourceUrl/chartjs'; 
import getStatusCount from '@salesforce/apex/ChartController.getStatusCount';

export default class GaugeChart extends LightningElement {
    chart;
    chartInitialized = false;
    statusData = null;

    @wire(getStatusCount)
    wiredStatusData({ error, data }) {
        if (data) {
            this.statusData = data;
            // FIXED: Changed 'gauge-chart' to 'gauge-canvas'
            if (this.chartInitialized && this.template.querySelector('canvas.gauge-canvas')) {
                this.renderChart();
            }
        } else if (error) {
            console.error('Error fetching status data:', error);
        }
    }

    renderedCallback() {
        if (this.chartInitialized) {
            return;
        }

        loadScript(this, chartjs)
            .then(() => {
                this.chartInitialized = true;
                if (this.statusData && Object.keys(this.statusData).length > 0) {
                    this.renderChart();
                }
            })
            .catch(error => {
                console.error('Error loading ChartJS library:', error);
            });
    }

    renderChart() {
        // FIXED: Changed 'gauge-chart' to 'gauge-canvas'
        const canvasElement = this.template.querySelector('canvas.gauge-canvas');
        if (!canvasElement) return;

        // SAFE SCOPE PICKER: LWS often hides Chart under globalThis or an evaluation scope
        const ChartJSConstructor = window.Chart || globalThis.Chart || Chart;
        
        if (!ChartJSConstructor) {
            console.error('Chart.js loaded, but constructor could not be found in any global scope.');
            return;
        }

        const ctx = canvasElement.getContext('2d');
        
        const labels = Object.keys(this.statusData);
        const counts = Object.values(this.statusData);
        const totalRecords = counts.reduce((sum, val) => sum + val, 0);

        const colorMap = {
            'Approved': '#FF5A79', 
            'Pending': '#34A2F2',  
            'Rejected': '#FBC44C'  
        };
        const backgroundColors = labels.map(label => colorMap[label] || '#9966FF');

        if (this.chart) {
            this.chart.destroy();
        }

        try {
            this.chart = new ChartJSConstructor(ctx, {
                type: 'doughnut', 
                data: {
                    labels: labels,
                    datasets: [{
                        data: counts,
                        backgroundColor: backgroundColors,
                        borderColor: '#ffffff',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',       
                    rotation: -90,       
                    circumference: 180,  
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                boxWidth: 12
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.parsed;
                                    const percentage = ((value / totalRecords) * 100).toFixed(1);
                                    return ` ${context.label}: ${value} (${percentage}%)`;
                                }
                            }
                        }
                    }
                }
            });
        } catch (domError) {
            console.error('Error constructing Chart instance:', domError);
        }
    }
}
