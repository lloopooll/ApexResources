public with sharing class ChartController {
    @AuraEnabled(cacheable=true)
    public static Map<String, Integer> getStatusCounts() {
        Map<String, Integer> resultMap = new Map<String, Integer>();
        
        // Aggregate query to count records grouped by Status
        for (AggregateResult ar : [SELECT Status__c, COUNT(Id) total FROM testChart__c GROUP BY Status__c]) {
            String statusValue = (String)ar.get('Status__c');
            Integer count = (Integer)ar.get('total');
            
            if (String.isBlank(statusValue)) {
                statusValue = 'Not Specified';
            }
            resultMap.put(statusValue, count);
        }
        return resultMap;
    }

    @AuraEnabled(cacheable=true)
    public static Map<String, Integer> getStatusCount() {
        Map<String, Integer> statusMap = new Map<String, Integer>();
        // Add your SOQL aggregate query logic here
        // Example output:
        statusMap.put('Approved', 15);
        statusMap.put('Pending', 8);
        statusMap.put('Rejected', 3);
        
        return statusMap;
    }

}
