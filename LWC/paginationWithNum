// Apex ...................................................................................

public class PaginationNumController {
    
    public class PagedResult {
        @AuraEnabled public Integer totalCount { get; set; }
        @AuraEnabled public List<Account> records { get; set; }
    }

    @AuraEnabled(cacheable=true)
    public static PagedResult getAccounts(Integer pageSize, Integer pageNumber) {
        PagedResult result = new PagedResult();
        
        // Calculate offset
        Integer offset = (pageNumber - 1) * pageSize;
        
        // Get total count for pagination math
        result.totalCount = [SELECT COUNT() FROM Account];
        
        // Fetch the specific page of records
        result.records = [SELECT Id, Name, Phone, Industry 
                          FROM Account 
                          ORDER BY Name 
                          LIMIT :pageSize 
                          OFFSET :offset];
                          
        return result;
    }

}

// HTML ...................................................................................

<template>
    <lightning-card title="Server-Side Pagination (Accounts)" icon-name="standard:account">
        <div class="slds-m-around_medium">
            
            <template if:true={accounts.length}>
                <div style="height: 300px;">
                    <lightning-datatable
                        key-field="Id"
                        data={accounts}
                        columns={columns}
                        hide-checkbox-column>
                    </lightning-datatable>
                </div>
            </template>

            <template if:true={error}>
                <div class="slds-text-color_error">Error loading data.</div>
            </template>

            <div class="slds-m-top_medium slds-grid slds-grid_align-center slds-grid_vertical-align-center">
                <div class="slds-button-group" role="group">
                    
                    <button class="slds-button slds-button_neutral" 
                            onclick={handlePrevious} 
                            disabled={isFirstPage}>
                        Previous
                    </button>

                    <template for:each={visiblePages} for:item="page">
                        <template if:true={page.isPage}>
                            <button key={page.label}
                                    data-page={page.label}
                                    onclick={handlePageClick}
                                    style="font-weight: bold;"
                                    class="slds-button slds-button_neutral theme-page-btn"
                                    disabled={page.active}>
                                {page.label}
                            </button>
                        </template>
                        
                        <template if:false={page.isPage}>
                            <span key={page.label} class="slds-p-horizontal_small slds-align-middle">
                                {page.label}
                            </span>
                        </template>
                    </template>

                    <button class="slds-button slds-button_neutral" 
                            onclick={handleNext} 
                            disabled={isLastPage}>
                        Next
                    </button>
                </div>
            </div>
            
            <div class="slds-text-align_center slds-m-top_x-small slds-text-color_weak">
                Page {pageNumber} of {totalPages} (Total Records: {totalCount})
            </div>

        </div>
    </lightning-card>
</template>

// JS ...................................................................................

import { LightningElement, wire, track } from 'lwc';
import getAccounts from '@salesforce/apex/PaginationNumController.getAccounts';

export default class PaginationWithNums extends LightningElement {
    @track accounts = [];
    @track error;

    // Pagination properties
    pageSize = 10;
    pageNumber = 1;
    totalCount = 0;
    totalPages = 0;
    visiblePages = [];

    // Columns for lightning-datatable
    columns = [
        { label: 'Account Name', fieldName: 'Name' },
        { label: 'Phone', fieldName: 'Phone', type: 'phone' },
        { label: 'Industry', fieldName: 'Industry' }
    ];

    // Wire the Apex method
    @wire(getAccounts, { pageSize: '$pageSize', pageNumber: '$pageNumber' })
    wiredAccounts({ error, data }) {
        if (data) {
            this.accounts = data.records;
            this.totalCount = data.totalCount;
            this.totalPages = Math.ceil(this.totalCount / this.pageSize);
            this.generatePageLinks();
            this.error = undefined;
        } else if (error) {
            this.error = error;
            this.accounts = [];
        }
    }

    // Generate page numbers logic: First 2 and Last 2 with Ellipsis
    generatePageLinks() {
        const pages = [];
        const total = this.totalPages;
        const current = this.pageNumber;

        if (total <= 4) {
            // If 4 or fewer pages, just show them all
            for (let i = 1; i <= total; i++) {
                pages.push({ label: i, isPage: true, active: i === current });
            }
        } else {
            // Always push first 2 pages
            pages.push({ label: 1, isPage: true, active: current === 1 });
            pages.push({ label: 2, isPage: true, active: current === 2 });

            // Handle middle section / ellipsis
            if (current > 2 && current < total - 1) {
                // If current page is in the middle, show it surrounded by ellipses
                if (current > 3) pages.push({ label: '...', isPage: false });
                pages.push({ label: current, isPage: true, active: true });
                if (current < total - 2) pages.push({ label: '...', isPage: false });
            } else {
                // Standard ellipsis between the first 2 and last 2
                pages.push({ label: '...', isPage: false });
            }

            // Always push last 2 pages
            pages.push({ label: total - 1, isPage: true, active: current === total - 1 });
            pages.push({ label: total, isPage: true, active: current === total });
        }
        this.visiblePages = pages;
    }

    // Navigation Handlers
    handlePrevious() {
        if (this.pageNumber > 1) {
            this.pageNumber--;
        }
    }

    handleNext() {
        if (this.pageNumber < this.totalPages) {
            this.pageNumber++;
        }
    }

    handlePageClick(event) {
        const pageClicked = parseInt(event.target.dataset.page, 10);
        if (pageClicked && pageClicked !== this.pageNumber) {
            this.pageNumber = pageClicked;
        }
    }

    // Disable button getters
    get isFirstPage() {
        return this.pageNumber === 1;
    }

    get isLastPage() {
        return this.pageNumber === this.totalPages || this.totalPages === 0;
    }
}

