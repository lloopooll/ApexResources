<template>
    <lightning-card title="Account List with onclick view action" icon-name="standard:account">
        <div class="slds-var-p-around_medium">
            <template if:true={accounts}>
                <ul class="slds-has-dividers_bottom-space">
                    <template for:each={accounts} for:item="acc">
                        <li key={acc.Id} 
                            class="slds-item slds-var-p-around_small list-row" 
                            data-id={acc.Id} 
                            onclick={handleRowClick}>
                            <div class="slds-grid slds-grid_vertical-align-center">
                                <div class="slds-col">
                                    <p class="slds-text-heading_small slds-text-link">{acc.Name}</p>
                                    <p class="slds-text-color_weak">Industry: {acc.Industry} | Phone: {acc.Phone}</p>
                                </div>
                            </div>
                        </li>
                    </template>
                </ul>
            </template>
            <template if:false={accounts}>
                <lightning-spinner alternative-text="Loading" size="medium"></lightning-spinner>
            </template>
        </div>
    </lightning-card>
</template>
