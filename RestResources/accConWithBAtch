// Rest Resource

.............................................................................

@RestResource(urlMapping='/accounts/batch')
global with sharing class RestResAccWithConBatch {

    @HttpPost
    global static String submitRequest() {

        String requestBody =
            RestContext.request.requestBody.toString();

        // Deserialize JSON → Wrapper
        AccountContactWrapper wrapper =
            (AccountContactWrapper) JSON.deserialize(
                requestBody,
                AccountContactWrapper.class
            );

        // Start Batch
        Id batchId = Database.executeBatch(
            new AccountContactBatch(wrapper),
            200
        );

        return 'Batch started successfully. BatchId = ' + batchId;
    }
}


